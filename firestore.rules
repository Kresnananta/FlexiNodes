rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Aturan untuk Demo: Hanya user yang sudah login (auth != null) yang bisa akses
    // Di produksi, aturan ini harus lebih ketat (misal: kurir hanya bisa lihat paketnya sendiri).
    
    match /deliveries/{deliveryId} {
      allow read, write: if request.auth != null;
    }
    
    match /nodes/{nodeId} {
      allow read: if request.auth != null;
      // Hanya backend (Admin SDK) atau peran admin yang boleh write data node
      allow write: if false; 
    }
  }
}
