rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // DELIVERIES: Untuk keperluan demo, izinkan user yang login untuk membaca dan menulis
    match /deliveries/{deliveryId} {
      allow read, write: if request.auth != null;
    }

    // USERS & DRIVERS: Frontend perlu membaca profil penerima dan kurir
    // berdasarkan receiverId/driverId dari dokumen deliveries.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys()
          .hasOnly(['currentLocation', 'lastLocationUpdatedAt']);
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['currentLocation', 'lastLocationUpdatedAt']);
      allow delete: if false;
    }
    
    // NODES: Semua user terotentikasi bisa membaca
    match /nodes/{nodeId} {
      allow read: if request.auth != null;
      allow write: if false; 
    }

    // OFFERS: Izinkan user membaca penawaran
    match /offers/{offerId} {
      allow read, write: if request.auth != null;
    }

    // AI_MESSAGE: Izinkan user membaca dan menulis chat
    match /AI_message/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}
